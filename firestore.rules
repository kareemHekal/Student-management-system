rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'd31nm90PspZ0M5VBJhZFlnUClhe2';
    }

    // Admin Full Access
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ===== Teachers =====
    match /teachers/{teacherId} {
      // Any authenticated user can READ the teacher doc (needed for referral code validation).
      // This only exposes the top-level doc (name, email, phone, subscription info).
      // Subcollections (students, passwords, invoices) are still restricted below.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == teacherId;
      allow update: if request.auth != null && request.auth.uid == teacherId;
      allow delete: if false;

      // All subcollections: only the owning teacher
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == teacherId;
      }
    }

    // ===== Referral Rewards Queue =====
    // New users create reward entries; host teacher reads + deletes their own
    match /referral_rewards/{rewardId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null
        && resource.data.hostTeacherId == request.auth.uid;
      allow update: if false;
    }

    // ===== Public read-only collections =====
    match /admin_subscriptions/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /admin_boost_subscriptions/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /admin_offers_subscriptions/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /app_settings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
